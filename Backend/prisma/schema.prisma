generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  phone        String?
  password     String
  role         Role
  status       Status        @default(active)
  location     String?
  avatarUrl    String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  buyer        Buyer?
  chatSessions ChatSession[]
  farmer       Farmer?
  seller       Seller?
  reviews      Review[]      @relation("UserReviews")
}

model Farmer {
  id                  String    @id @default(cuid())
  userId              String    @unique
  location            String
  farmSize            String?
  mainCrops           Json?
  soilType            String?
  hasIrrigation       Boolean?  @default(false)
  experience          String?
  onboardingCompleted Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  fields              Field[]
  listings            Listing[]
  matches             Match[]
}

model Field {
  id             String    @id @default(cuid())
  farmerId       String
  location       String
  crop           CropType
  area           Float
  ndvi           Float     @default(0)
  soilMoisture   Float     @default(0)
  lastIrrigation DateTime?
  status         Status    @default(active)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  alerts         Alert[]
  farmer         Farmer    @relation(fields: [farmerId], references: [id], onDelete: Cascade)
}

model Buyer {
  id                  String           @id @default(cuid())
  userId              String           @unique
  preferredLocation   String?
  preferredCrops      Json?
  purchaseFrequency   String?
  preferredQuantity   Int?
  deliveryPreference  String?
  maxDistance         Int?             @default(15)
  onboardingCompleted Boolean          @default(false)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  user                User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  demands             Demand[]
  requests            ListingRequest[]
  matches             Match[]
  orders              Order[]
  reviews             Review[]         // Reviews written by this buyer
}

model Seller {
  id        String    @id @default(cuid())
  userId    String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  listings  Listing[]
  matches   Match[]
  orders    Order[]
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviews   Review[]  // Reviews received by this seller
}

model Listing {
  id           String           @id @default(cuid())
  sellerId     String
  farmerId     String?
  cropType     CropType
  quantity     Int
  remainingQty Int
  location     String
  description  String
  photoUrl     String?
  status       ListingStatus    @default(available)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  farmer       Farmer?          @relation(fields: [farmerId], references: [id])
  seller       Seller           @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  requests     ListingRequest[]
  matches      Match[]
}

model Demand {
  id        String       @id @default(cuid())
  buyerId   String
  cropType  CropType
  quantity  Int
  location  String
  status    DemandStatus @default(pending)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  buyer     Buyer        @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  matches   Match[]
}

model ListingRequest {
  id            String        @id @default(cuid())
  listingId     String
  buyerId       String
  requestedQty  Int
  message       String?
  buyerLocation String        @default("")
  status        RequestStatus @default(pending)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  buyer         Buyer         @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  listing       Listing       @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model Match {
  id             String      @id @default(cuid())
  listingId      String
  demandId       String?
  requestId      String?
  buyerId        String
  sellerId       String
  farmerId       String?
  cropType       CropType
  quantity       Int
  buyerLocation  String
  sellerLocation String
  distance       Float       @default(0)
  status         MatchStatus @default(pending)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  aiConfidence   Float?      @default(0)
  aiScore        Int?        @default(0)
  isAIGenerated  Boolean     @default(false)
  matchReasons   String[]    @default([])
  buyer          Buyer       @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  demand         Demand?     @relation(fields: [demandId], references: [id])
  farmer         Farmer?     @relation(fields: [farmerId], references: [id])
  listing        Listing     @relation(fields: [listingId], references: [id], onDelete: Cascade)
  seller         Seller      @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  order          Order?
}

model Order {
  id              String      @id @default(dbgenerated("gen_random_uuid()"))
  matchId         String      @unique
  buyerId         String
  sellerId        String
  status          OrderStatus @default(placed)
  statusHistory   Json        @default("[]")
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @default(now()) @updatedAt
  sellerConfirmed Boolean     @default(false)
  buyerConfirmed  Boolean     @default(false)
  buyer           Buyer       @relation(fields: [buyerId], references: [id], onUpdate: NoAction)
  match           Match       @relation(fields: [matchId], references: [id], onUpdate: NoAction)
  seller          Seller      @relation(fields: [sellerId], references: [id], onUpdate: NoAction)
  review          Review?     // One-to-one relationship with Review
}

model Review {
  id         String   @id @default(cuid())
  orderId    String   @unique
  order      Order    @relation(fields: [orderId], references: [id])
  reviewerId String
  reviewer   User     @relation("UserReviews", fields: [reviewerId], references: [id])
  buyerId    String?
  buyer      Buyer?   @relation(fields: [buyerId], references: [id])
  sellerId   String
  seller     Seller   @relation(fields: [sellerId], references: [id])
  rating     Int
  comment    String?  @db.Text
  createdAt  DateTime @default(now())
}

model Alert {
  id         String        @id @default(cuid())
  fieldId    String
  type       String
  severity   AlertSeverity
  resolved   Boolean       @default(false)
  resolvedAt DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  field      Field         @relation(fields: [fieldId], references: [id], onDelete: Cascade)
}

model ContentImage {
  id          String   @id @default(cuid())
  key         String   @unique
  label       String
  description String
  page        String
  imageUrl    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ChatSession {
  id        String        @id @default(cuid())
  userId    String
  title     String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  role      String
  content   String
  createdAt DateTime    @default(now())
  isVoice   Boolean     @default(false)
  voiceText String?
  language  String?
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

enum Role {
  farmer
  buyer
  seller
  admin
}

enum Status {
  active
  suspended
}

enum AlertSeverity {
  info
  warning
  critical
}

enum CropType {
  Maize
  Cassava
  Tomato
  Pepper
}

enum ListingStatus {
  available
  partial
  sold
}

enum DemandStatus {
  pending
  matched
  expired
}

enum RequestStatus {
  pending
  accepted
  rejected
  completed
}

enum MatchStatus {
  pending
  confirmed
  declined
}

enum OrderStatus {
  placed
  accepted
  preparing
  transport_assigned
  in_transit
  delivered
  completed
  cancelled
}